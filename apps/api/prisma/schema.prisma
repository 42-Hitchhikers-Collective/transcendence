generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  BANNED
  DELETED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum LobbyStatus {
  OPEN
  IN_GAME
  CLOSED
}

enum GameStatus {
  RUNNING
  FINISHED
  ABORTED
}

enum ConversationType {
  DM
  LOBBY
  GAME
}

enum NotificationType {
  FRIEND_REQUEST
  INVITE
  GAME_RESULT
  SYSTEM
}


/* ---------------------------------- CORE ---------------------------------- */
model User {
  id              String     @id @default(uuid())
  email           String     @unique
  passwordHash    String?
  status          UserStatus @default(ACTIVE)
  isEmailVerified Boolean    @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile Profile?

  // Auth options (choose in code)
  refreshTokens RefreshToken[]
  authSessions  AuthSession[]

  // Tokens (email verify / password reset)
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]

  // OAuth
  oauthAccounts OAuthAccount[]

  // Roles
  userRoles UserRole[]

  // Social
  friendRequestsSent     FriendRequest[] @relation("FriendRequestsSent")
  friendRequestsReceived FriendRequest[] @relation("FriendRequestsReceived")
  friendshipsA           Friendship[]    @relation("FriendshipA")
  friendshipsB           Friendship[]    @relation("FriendshipB")
  blocksMade             Block[]         @relation("BlocksMade")
  blocksReceived         Block[]         @relation("BlocksReceived")

  // Lobbies / Games
  hostedLobbies Lobby[]       @relation("HostedLobbies")
  lobbyMembers  LobbyMember[]
  invitesSent   Invite[]      @relation("InvitesSent")
  invitesRecv   Invite[]      @relation("InvitesRecv")
  gamePlayers   GamePlayer[]

  // Chat
  conversationMembers ConversationMember[]
  messages            Message[]

  // Notifications
  notifications Notification[]

  // Files
  files File[]



}

model Profile {
  userId      String  @id
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName String
  avatarUrl   String?
  bio         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/* --------------------------- AUTH / SECURITY FLOWS -------------------------- */

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model AuthSession {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?

  createdAt DateTime @default(now())

  @@index([userId])
}

/* ----------------------------- ROLES / PERMS ----------------------------- */

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  userRoles UserRole[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
}

/* ---------------------------------- SOCIAL ---------------------------------- */

model FriendRequest {
  id        String   @id @default(uuid())
  fromUserId String
  toUserId   String
  createdAt DateTime @default(now())

  fromUser User @relation("FriendRequestsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User @relation("FriendRequestsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@unique([fromUserId, toUserId])
}

model Friendship {
  userAId  String
  userBId  String
  createdAt DateTime @default(now())

  userA User @relation("FriendshipA", fields: [userAId], references: [id], onDelete: Cascade)
  userB User @relation("FriendshipB", fields: [userBId], references: [id], onDelete: Cascade)

  @@id([userAId, userBId])
  @@index([userBId])
}

model Block {
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("BlocksMade", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockedId])
}

/* ------------------------------ LOBBIES / INVITES ------------------------------ */

model Lobby {
  id         String      @id @default(uuid())
  hostUserId String
  host       User        @relation("HostedLobbies", fields: [hostUserId], references: [id], onDelete: Cascade)

  status     LobbyStatus @default(OPEN)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members LobbyMember[]
  invites Invite[]
  games   Game[]

  @@index([hostUserId])
}

model LobbyMember {
  lobbyId String
  userId  String
  ready   Boolean @default(false)
  joinedAt DateTime @default(now())

  lobby Lobby @relation(fields: [lobbyId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([lobbyId, userId])
  @@index([userId])
}

model Invite {
  id        String       @id @default(uuid())
  fromUserId String
  toUserId   String
  lobbyId    String?

  status InviteStatus @default(PENDING)
  createdAt DateTime @default(now())

  fromUser User  @relation("InvitesSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User  @relation("InvitesRecv", fields: [toUserId], references: [id], onDelete: Cascade)
  lobby    Lobby? @relation(fields: [lobbyId], references: [id], onDelete: Cascade)

  @@index([fromUserId])
  @@index([toUserId])
  @@index([lobbyId])
}

/* ---------------------------------- GAMES ---------------------------------- */

model Game {
  id        String     @id @default(uuid())
  lobbyId   String?
  lobby     Lobby?     @relation(fields: [lobbyId], references: [id], onDelete: SetNull)

  status    GameStatus @default(RUNNING)

  createdAt DateTime @default(now())
  endedAt   DateTime?

  players GamePlayer[]
}

model GamePlayer {
  gameId String
  userId String

  score Int?

  game Game @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([gameId, userId])
  @@index([userId])
}

/* ----------------------------------- CHAT ----------------------------------- */

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  createdAt DateTime         @default(now())

  members ConversationMember[]
  messages Message[]
}

model ConversationMember {
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String   @id @default(uuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)


  @@index([conversationId])
  @@index([senderId])
}

/* ------------------------------- NOTIFICATIONS ------------------------------ */

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([readAt])
}

/* ----------------------------------- OAUTH ---------------------------------- */

model OAuthAccount {
  id                String @id @default(uuid())
  userId            String
  provider          String
  providerAccountId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/* ----------------------------------- FILES ---------------------------------- */

model File {
  id        String   @id @default(uuid())
  ownerId   String
  url       String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  owner User @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}




